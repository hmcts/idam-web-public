<suppressions xmlns="https://jeremylong.github.io/DependencyCheck/dependency-suppression.1.3.xsd">

    <!-- JSTL/ XML‐based tags not used -->
    <suppress>
        <notes><![CDATA[
        file name: jstl-1.2.jar
        ]]></notes>
        <gav regex="true">^.*$</gav>
        <cve>CVE-2015-0254</cve>
    </suppress>

    <!-- Spring 2.x vulnerabilities until we move to Spring 3+ -->
    <suppress>
        <gav regex="true">^.*org\.springframework.*$</gav>
        <cve>CVE-2016-1000027</cve>
        <cve>CVE-2020-5408</cve>
        <cve>CVE-2024-38820</cve>
    </suppress>

    <!-- Logback CVEs blocked by Spring Boot version -->
    <suppress base="true">
        <gav regex="true">^.*logback.*$</gav>
        <cve>CVE-2023-6378</cve>
        <cve>CVE-2023-6481</cve>
    </suppress>

    <!--
    commons-configuration-1.8 is a transitive dependency of spring-cloud-starter-netflix-zuul:
    neither has an upgrade path
    -->
    <suppress>
        <gav regex="true">^.*commons-configuration.*$</gav>
        <cve>CVE-2025-46392</cve>
    </suppress>

    <!-- False positive: CVEs apply to Go distribution, not Netflix Java stats jar -->
    <suppress>
        <notes><![CDATA[
        False positive: netflix-statistics-0.1.1.jar is a Maven Java artifact.
        CVE-2026-33540, CVE-2026-35172, and CVE-2026-41888 apply to
        github.com/distribution/distribution (Go), not this package. Suppressed by exact
        SHA-1 to avoid CPE matcher differences.
        ]]></notes>
        <sha1>12F6E48253F9CAFA0E24D7D232FF504C52143212</sha1>
        <cve>CVE-2026-33540</cve>
        <cve>CVE-2026-35172</cve>
        <cve>CVE-2026-41888</cve>
    </suppress>

    <!--
    False positive: CVE-2026-42582 applies to io.netty:netty-codec-http3
    4.2.0.Final through 4.2.12.Final and is fixed in 4.2.13.Final. This project is
    on Netty 4.1.135.Final and does not depend on netty-codec-http3; Dependency-Check
    is matching the generic netty CPE against non-HTTP/3 Netty artifacts.
    -->
    <suppress>
        <gav regex="true">^io\.netty:netty-(buffer|codec|common|handler|resolver|transport|transport-native-unix-common):4\.1\.135\.Final$</gav>
        <cve>CVE-2026-42582</cve>
    </suppress>

    <!--
    Not exploitable in this application. Spring's advisories for CVE-2026-40988,
    CVE-2026-41003, and CVE-2026-41694 require Spring Security SAML service-provider
    functionality, such as spring-security-saml2-service-provider, SAML login/logout,
    or attacker-influenced RelyingPartyRegistration values. The checked codebase does
    not depend on spring-security-saml2-service-provider and has no SAML configuration
    or RelyingPartyRegistration usage. The fixed Spring Security 5.7.x and 5.8.x
    versions are enterprise-support-only; public OSS fixes require moving to Spring
    Security 6.5+ / Spring Boot 3, which is disproportionate for this JSP Spring Boot
    2.7 maintenance-mode application.
    -->
    <suppress>
        <gav regex="true">^.*org\.springframework\.security:spring-security-.*$</gav>
        <cve>CVE-2026-40988</cve>
        <cve>CVE-2026-41003</cve>
        <cve>CVE-2026-41694</cve>
    </suppress>

    <!--
    Spring's advisory for CVE-2026-22732 lists 5.7.22 as the fixed 5.7.x release, but that line is
    enterprise-support-only. This application applies Spring's documented workaround by forcing eager
    header writing in both security configurations, which addresses the vulnerable behavior while the
    project remains on the public Spring Boot 2.7 / Spring Security 5.7 line.
    -->
    <suppress>
        <gav regex="true">^.*org\.springframework\.security:spring-security-.*$</gav>
        <cve>CVE-2026-22732</cve>
    </suppress>

    <!--
    Not exploitable in this application. Spring's advisory for CVE-2026-22733 requires a protected
    application endpoint to be mounted under the Cloud Foundry actuator path, for example
    /cloudfoundryapplication/**. This application does not expose Cloud Foundry actuator endpoints,
    only exposes health/info/prometheus under the root actuator base path, and does not mount any
    application endpoints beneath a Cloud Foundry actuator path.
    -->
    <suppress>
        <gav regex="true">^.*org\.springframework\.boot:.*$</gav>
        <cve>CVE-2026-22733</cve>
    </suppress>

    <!--
    Not exploitable in this application. Spring's advisory for CVE-2026-22735 requires Server-Sent
    Events (SSE) usage that streams attacker-controlled plain text to other users. This application
    does not use SSE: there are no SseEmitter, ServerSentEvent, or text/event-stream handlers in the
    codebase.
    -->
    <suppress>
        <gav regex="true">^.*org\.springframework:.*$</gav>
        <cve>CVE-2026-22735</cve>
    </suppress>

    <!--
    Not exploitable in this application. Spring's advisory for CVE-2026-41838 applies to the
    spring-websocket module when WebSocket session IDs interact with inadequate authorization rules.
    The checked codebase does not depend on spring-websocket and does not configure Spring WebSocket,
    STOMP, SockJS, WebSocketHandler, or @EnableWebSocket. The only websocket artifact found is
    Tomcat's embedded websocket support.
    -->
    <suppress>
        <gav regex="true">^.*org\.springframework:.*$</gav>
        <cve>CVE-2026-41838</cve>
    </suppress>

    <!--
    Not exploitable in this application. Spring's advisory for CVE-2026-22740 applies to WebFlux
    server multipart processing, where large multipart parts are written to temp files by the
    reactive stack. This application is a servlet-based Spring Boot application using
    spring-boot-starter-web, embedded Tomcat, and Zuul; the checked codebase does not use
    spring-boot-starter-webflux, WebFlux handlers, or reactive multipart request processing.
    -->
    <suppress>
        <gav regex="true">^.*org\.springframework:.*$</gav>
        <cve>CVE-2026-22740</cve>
    </suppress>

    <!--
    Not exploitable in this application. Spring's advisory for CVE-2026-41840 applies to WebFlux
    multipart request processing. This application is a servlet-based Spring Boot application using
    spring-boot-starter-web, embedded Tomcat, and Zuul; the checked codebase does not use
    spring-boot-starter-webflux, WebFlux handlers, or multipart request processing.
    -->
    <suppress>
        <gav regex="true">^.*org\.springframework:.*$</gav>
        <cve>CVE-2026-41840</cve>
    </suppress>

    <!--
    Not exploitable in this application. Spring's advisory for CVE-2026-41853 requires a Spring MVC
    or WebFlux application that accepts multipart requests, together with a WAF or proxy that parses
    multipart content and performs checks based on it. This application is servlet-based but does not
    expose multipart request handling: the checked codebase does not use MultipartFile, Part,
    @RequestPart, multipart/form-data, MultipartResolver, spring.servlet.multipart configuration, or
    WebFlux PartEvent processing. The Spring Framework 5.3.x fixed version is enterprise-support-only;
    public OSS fixes require moving to Spring Framework 6.2+ / Spring Boot 3, which is disproportionate
    for this JSP Spring Boot 2.7 maintenance-mode application.
    -->
    <suppress>
        <gav regex="true">^.*org\.springframework:.*$</gav>
        <cve>CVE-2026-41853</cve>
    </suppress>

    <!--
    Not exploitable in this application. Spring's advisory for CVE-2026-41847 requires Spring
    WebFlux, the Kotlin Router DSL, and a filter that passes a modified or replaced ServerRequest to
    the next handler function. This application is servlet-based, does not use WebFlux, and contains
    no Kotlin Router DSL, RouterFunction, ServerRequestWrapper, or reactive handler functions.
    -->
    <suppress>
        <gav regex="true">^.*org\.springframework:.*$</gav>
        <cve>CVE-2026-41847</cve>
    </suppress>

    <!--
    Not exploitable in this application. Spring's advisory for CVE-2026-22741 requires static
    resource chain caching together with encoded resource resolution for precompressed assets.
    The checked codebase does not configure resourceChain/addResourceHandlers, does not use
    EncodedResourceResolver or related spring.resources/spring.web.resources chain settings, and
    does not ship precompressed static assets such as .gz or .br files under the served static
    resource locations.
    -->
    <suppress>
        <gav regex="true">^.*org\.springframework:.*$</gav>
        <cve>CVE-2026-22741</cve>
    </suppress>

    <!--
    Not exploitable in this application. Spring's advisory for CVE-2026-22745 requires a Spring
    MVC or WebFlux application to serve static resources from filesystem-backed locations on a
    Windows platform. The checked codebase serves bundled classpath static resources, does not
    configure file: resource locations or custom filesystem-backed ResourceHandlers, and the
    primary deployment artifacts in this repository target Linux containers/Kubernetes.
    -->
    <suppress>
        <gav regex="true">^.*org\.springframework:.*$</gav>
        <cve>CVE-2026-22745</cve>
    </suppress>

    <!--
    Not exploitable in this application. Spring's advisories for CVE-2026-41841, CVE-2026-41842,
    and CVE-2026-41843 require static resource handler configurations this application does not use.
    CVE-2026-41841 requires several resource handlers, at least one authenticated resource handler,
    and a shared resource cache. CVE-2026-41842 and CVE-2026-41843 require filesystem-backed static
    resources plus versioned resources support. The checked codebase does not configure
    addResourceHandlers/resourceChain/versioned resources, does not use file: resource locations,
    and serves bundled classpath static assets.
    -->
    <suppress>
        <gav regex="true">^.*org\.springframework:.*$</gav>
        <cve>CVE-2026-41841</cve>
        <cve>CVE-2026-41842</cve>
        <cve>CVE-2026-41843</cve>
    </suppress>

    <!--
    Not exploitable in this application. Spring's advisory for CVE-2026-41844 requires a Spring MVC
    or WebFlux /** mapping where the view name is not explicitly specified, allowing crafted
    redirect: or forward: view-name prefixes. The checked controllers do not define a /** mapping;
    mappings are explicit and redirect view names are fixed application paths.
    -->
    <suppress>
        <gav regex="true">^.*org\.springframework:.*$</gav>
        <cve>CVE-2026-41844</cve>
    </suppress>

    <!--
    Not exploitable in this application. Spring's advisory for CVE-2026-22737 requires ScriptTemplate
    views (for example JRuby or Jython) together with a /** mapping that renders an implicit view.
    This application uses JSP views under /WEB-INF/jsp and does not configure ScriptTemplate view
    rendering or a catch-all /** controller mapping.
    -->
    <suppress>
        <gav regex="true">^.*org\.springframework:.*$</gav>
        <cve>CVE-2026-22737</cve>
    </suppress>

    <!--
    Not exploitable in this application. Spring's advisory for CVE-2026-41845 requires use of
    JavaScriptUtils.javaScriptEscape(), which may incorrectly escape attacker-controlled content.
    The checked codebase does not use JavaScriptUtils, javaScriptEscape, or equivalent Spring
    JavaScript escaping helpers.
    -->
    <suppress>
        <gav regex="true">^.*org\.springframework:.*$</gav>
        <cve>CVE-2026-41845</cve>
    </suppress>

    <!--
    Not exploitable in this application. Spring's advisory for CVE-2026-41846 requires Spring MVC
    JSP form tags where cssClass, cssErrorClass, or cssStyle attributes are populated from
    user-supplied values. This application uses JSP form tags, but the checked JSP/tag files do not
    use cssClass, cssErrorClass, or cssStyle attributes on form:* tags.
    -->
    <suppress>
        <gav regex="true">^.*org\.springframework:.*$</gav>
        <cve>CVE-2026-41846</cve>
    </suppress>

    <!--
    Not exploitable in this application. Spring's advisory for CVE-2026-41848 requires an
    attacker-supplied pattern to be passed directly or indirectly to AntPathMatcher match,
    matchStart, or extractUriTemplateVariables. The checked codebase does not use AntPathMatcher or
    PathMatcher directly, and Spring MVC/Security route patterns are static application literals.
    -->
    <suppress>
        <gav regex="true">^.*org\.springframework:.*$</gav>
        <cve>CVE-2026-41848</cve>
    </suppress>

    <!--
    Not exploitable in this application. Spring's advisories for CVE-2026-41849, CVE-2026-41850,
    CVE-2026-41851, and CVE-2026-41852 require accepting and evaluating untrusted or
    user-controlled SpEL expressions; CVE-2026-41851 also requires caching parsed SpEL expressions.
    The checked codebase does not use ExpressionParser, SpelExpressionParser, parseExpression, or
    any custom user-controlled SpEL evaluation. The only SpEL usage found is static application-owned
    JSP spring:eval expressions and normal @Value property binding.
    -->
    <suppress>
        <gav regex="true">^.*org\.springframework:.*$</gav>
        <cve>CVE-2026-41849</cve>
        <cve>CVE-2026-41850</cve>
        <cve>CVE-2026-41851</cve>
        <cve>CVE-2026-41852</cve>
    </suppress>

    <!--
       Spring's advisory for CVE-2026-22746 lists 5.7.23 as the fixed 5.7.x release, but that line is
       enterprise-support-only. There is no public OSS Spring Security 5.7 upgrade path while this
       project remains on Spring Boot 2.7 / Spring Security 5.7. A dependency-level fix requires either
       enterprise-supported Spring Security 5.x artifacts or a Spring Boot 3 / Spring Security 6+ upgrade.
       -->
    <suppress>
        <gav regex="true">^.*org\.springframework\.security:spring-security-.*$</gav>
        <cve>CVE-2026-22746</cve>
    </suppress>

    <!--
    Spring's advisory for CVE-2026-22748 does not provide a public OSS Spring Security 5.7 fix.
    The public fixed versions are on supported Spring Security 6.5 and 7.0 lines, so resolving this
    at dependency level requires either enterprise-supported Spring Security 5.x artifacts or a
    Spring Boot 3 / Spring Security 6+ upgrade.
    -->
    <suppress>
        <gav regex="true">^.*org\.springframework\.security:spring-security-.*$</gav>
        <cve>CVE-2026-22748</cve>
    </suppress>

    <!--
    Not exploitable in this application. Spring's advisory for CVE-2026-40977 requires the
    ApplicationPidFileWriter feature, or equivalent PID-file configuration such as spring.pid.file.
    This application starts via SpringApplication.run without registering ApplicationPidFileWriter,
    and the codebase plus checked Docker/Helm configuration do not set spring.pid.file,
    application.pid, or equivalent PID-file startup options.
    -->
    <suppress>
        <gav regex="true">^.*org\.springframework\.boot:.*$</gav>
        <cve>CVE-2026-40977</cve>
    </suppress>

    <!--
    Not exploitable in this application. Spring's advisory for CVE-2026-40975 requires use of
    ${random.value} as a secret, or similar ${random.int}/${random.long} usage in a security
    context. The checked codebase and manifests do not use ${random.value}, ${random.int},
    ${random.long}, or ${random.uuid} in application configuration, and secrets are sourced
    externally rather than generated from Spring Boot's random value property source.
    -->
    <suppress>
        <gav regex="true">^.*org\.springframework\.boot:.*$</gav>
        <cve>CVE-2026-40975</cve>
    </suppress>

    <!--
    Not exploitable in this application. Spring's advisory for CVE-2026-40974 applies to
    Cassandra SSL auto-configuration, where Spring Boot establishes an SSL connection to
    Cassandra without TLS hostname verification. This application does not depend on
    Cassandra/DataStax, does not use spring-boot-starter-data-cassandra, and the checked
    codebase/manifests do not configure spring.cassandra.* or spring.data.cassandra.* properties.
    -->
    <suppress>
        <gav regex="true">^.*org\.springframework\.boot:.*$</gav>
        <cve>CVE-2026-40974</cve>
    </suppress>

    <!--
    Not exploitable in this application. Spring's advisory for CVE-2026-40973 requires use of the
    vulnerable ApplicationTemp path in a context such as server.servlet.session.persistent=true
    across restarts. This application does not enable server.servlet.session.persistent and uses
    Redis-backed Spring Session instead of persisted servlet-container sessions.
    -->
    <suppress>
        <gav regex="true">^.*org\.springframework\.boot:.*$</gav>
        <cve>CVE-2026-40973</cve>
    </suppress>

    <!--
    Not exploitable in this application. Spring's advisory for CVE-2026-40972 applies to remote
    Spring Boot DevTools when a remote secret is configured. This codebase only includes
    spring-boot-devtools as a test dependency and does not configure spring.devtools.remote.secret
    or other remote DevTools settings in the checked code or manifests.
    -->
    <suppress>
        <gav regex="true">^.*org\.springframework\.boot:.*$</gav>
        <cve>CVE-2026-40972</cve>
    </suppress>

</suppressions>
