<suppressions xmlns="https://jeremylong.github.io/DependencyCheck/dependency-suppression.1.3.xsd">

    <!-- JSTL/ XML‐based tags not used -->
    <suppress>
        <notes><![CDATA[
        file name: jstl-1.2.jar
        ]]></notes>
        <gav regex="true">^.*$</gav>
        <cve>CVE-2015-0254</cve>
    </suppress>

    <!-- Spring 2.x vulnerabilities until we move to Spring 3+ -->
    <suppress>
        <gav regex="true">^.*org\.springframework.*$</gav>
        <cve>CVE-2016-1000027</cve>
        <cve>CVE-2020-5408</cve>
        <cve>CVE-2024-38820</cve>
    </suppress>

    <!-- Logback CVEs blocked by Spring Boot version -->
    <suppress base="true">
        <gav regex="true">^.*logback.*$</gav>
        <cve>CVE-2023-6378</cve>
        <cve>CVE-2023-6481</cve>
    </suppress>

    <!--
    commons-configuration-1.8 is a transitive dependency of spring-cloud-starter-netflix-zuul:
    neither has an upgrade path
    -->
    <suppress>
        <gav regex="true">^.*commons-configuration.*$</gav>
        <cve>CVE-2025-46392</cve>
    </suppress>

    <!-- False positive: CVE applies to Go distribution, not Netflix Java stats jar -->
    <suppress>
        <notes><![CDATA[
        False positive: netflix-statistics-0.1.1.jar is a Maven Java artifact. CVE-2026-33540
        applies to github.com/distribution/distribution (Go), not this package. Suppressed by
        exact SHA-1 to avoid CPE matcher differences.
        ]]></notes>
        <sha1>12F6E48253F9CAFA0E24D7D232FF504C52143212</sha1>
        <cve>CVE-2026-33540</cve>
    </suppress>

    <!--
    False positive: CVE-2026-42582 applies to io.netty:netty-codec-http3 <= 4.2.12.Final.
    This project is on Netty 4.1.133.Final and Dependency Check is matching the generic
    netty CPE against non-HTTP/3 artifacts. Netty 4.1.133.Final is the Netty 4.1 security
    release that includes the CVE-2026-42582 fix.
    -->
    <suppress>
        <gav regex="true">^io\.netty:netty-(buffer|codec|common|handler|resolver|transport|transport-native-unix-common):4\.1\.133\.Final$</gav>
        <cve>CVE-2026-42582</cve>
    </suppress>

    <!--
    Spring's advisory for CVE-2026-22732 lists 5.7.22 as the fixed 5.7.x release, but that line is
    enterprise-support-only. This application applies Spring's documented workaround by forcing eager
    header writing in both security configurations, which addresses the vulnerable behavior while the
    project remains on the public Spring Boot 2.7 / Spring Security 5.7 line.
    -->
    <suppress>
        <gav regex="true">^.*org\.springframework\.security:spring-security-.*$</gav>
        <cve>CVE-2026-22732</cve>
    </suppress>

    <!--
    Not exploitable in this application. Spring's advisory for CVE-2026-22733 requires a protected
    application endpoint to be mounted under the Cloud Foundry actuator path, for example
    /cloudfoundryapplication/**. This application does not expose Cloud Foundry actuator endpoints,
    only exposes health/info/prometheus under the root actuator base path, and does not mount any
    application endpoints beneath a Cloud Foundry actuator path.
    -->
    <suppress>
        <gav regex="true">^.*org\.springframework\.boot:.*$</gav>
        <cve>CVE-2026-22733</cve>
    </suppress>

    <!--
    Not exploitable in this application. Spring's advisory for CVE-2026-22735 requires Server-Sent
    Events (SSE) usage that streams attacker-controlled plain text to other users. This application
    does not use SSE: there are no SseEmitter, ServerSentEvent, or text/event-stream handlers in the
    codebase.
    -->
    <suppress>
        <gav regex="true">^.*org\.springframework:.*$</gav>
        <cve>CVE-2026-22735</cve>
    </suppress>

    <!--
    Not exploitable in this application. Spring's advisory for CVE-2026-22740 applies to WebFlux
    server multipart processing, where large multipart parts are written to temp files by the
    reactive stack. This application is a servlet-based Spring Boot application using
    spring-boot-starter-web, embedded Tomcat, and Zuul; the checked codebase does not use
    spring-boot-starter-webflux, WebFlux handlers, or reactive multipart request processing.
    -->
    <suppress>
        <gav regex="true">^.*org\.springframework:.*$</gav>
        <cve>CVE-2026-22740</cve>
    </suppress>

    <!--
    Not exploitable in this application. Spring's advisory for CVE-2026-22741 requires static
    resource chain caching together with encoded resource resolution for precompressed assets.
    The checked codebase does not configure resourceChain/addResourceHandlers, does not use
    EncodedResourceResolver or related spring.resources/spring.web.resources chain settings, and
    does not ship precompressed static assets such as .gz or .br files under the served static
    resource locations.
    -->
    <suppress>
        <gav regex="true">^.*org\.springframework:.*$</gav>
        <cve>CVE-2026-22741</cve>
    </suppress>

    <!--
    Not exploitable in this application. Spring's advisory for CVE-2026-22745 requires a Spring
    MVC or WebFlux application to serve static resources from filesystem-backed locations on a
    Windows platform. The checked codebase serves bundled classpath static resources, does not
    configure file: resource locations or custom filesystem-backed ResourceHandlers, and the
    primary deployment artifacts in this repository target Linux containers/Kubernetes.
    -->
    <suppress>
        <gav regex="true">^.*org\.springframework:.*$</gav>
        <cve>CVE-2026-22745</cve>
    </suppress>

    <!--
    Not exploitable in this application. Spring's advisory for CVE-2026-22737 requires ScriptTemplate
    views (for example JRuby or Jython) together with a /** mapping that renders an implicit view.
    This application uses JSP views under /WEB-INF/jsp and does not configure ScriptTemplate view
    rendering or a catch-all /** controller mapping.
    -->
    <suppress>
        <gav regex="true">^.*org\.springframework:.*$</gav>
        <cve>CVE-2026-22737</cve>
    </suppress>

    <!--
       Spring's advisory for CVE-2026-22746 lists 5.7.23 as the fixed 5.7.x release, but that line is
       enterprise-support-only. There is no public OSS Spring Security 5.7 upgrade path while this
       project remains on Spring Boot 2.7 / Spring Security 5.7. A dependency-level fix requires either
       enterprise-supported Spring Security 5.x artifacts or a Spring Boot 3 / Spring Security 6+ upgrade.
       -->
    <suppress>
        <gav regex="true">^.*org\.springframework\.security:spring-security-.*$</gav>
        <cve>CVE-2026-22746</cve>
    </suppress>

    <!--
    Spring's advisory for CVE-2026-22748 does not provide a public OSS Spring Security 5.7 fix.
    The public fixed versions are on supported Spring Security 6.5 and 7.0 lines, so resolving this
    at dependency level requires either enterprise-supported Spring Security 5.x artifacts or a
    Spring Boot 3 / Spring Security 6+ upgrade.
    -->
    <suppress>
        <gav regex="true">^.*org\.springframework\.security:spring-security-.*$</gav>
        <cve>CVE-2026-22748</cve>
    </suppress>

    <!--
    Not exploitable in this application. Spring's advisory for CVE-2026-40977 requires the
    ApplicationPidFileWriter feature, or equivalent PID-file configuration such as spring.pid.file.
    This application starts via SpringApplication.run without registering ApplicationPidFileWriter,
    and the codebase plus checked Docker/Helm configuration do not set spring.pid.file,
    application.pid, or equivalent PID-file startup options.
    -->
    <suppress>
        <gav regex="true">^.*org\.springframework\.boot:.*$</gav>
        <cve>CVE-2026-40977</cve>
    </suppress>

    <!--
    Not exploitable in this application. Spring's advisory for CVE-2026-40975 requires use of
    ${random.value} as a secret, or similar ${random.int}/${random.long} usage in a security
    context. The checked codebase and manifests do not use ${random.value}, ${random.int},
    ${random.long}, or ${random.uuid} in application configuration, and secrets are sourced
    externally rather than generated from Spring Boot's random value property source.
    -->
    <suppress>
        <gav regex="true">^.*org\.springframework\.boot:.*$</gav>
        <cve>CVE-2026-40975</cve>
    </suppress>

    <!--
    Not exploitable in this application. Spring's advisory for CVE-2026-40974 applies to
    Cassandra SSL auto-configuration, where Spring Boot establishes an SSL connection to
    Cassandra without TLS hostname verification. This application does not depend on
    Cassandra/DataStax, does not use spring-boot-starter-data-cassandra, and the checked
    codebase/manifests do not configure spring.cassandra.* or spring.data.cassandra.* properties.
    -->
    <suppress>
        <gav regex="true">^.*org\.springframework\.boot:.*$</gav>
        <cve>CVE-2026-40974</cve>
    </suppress>

    <!--
    Not exploitable in this application. Spring's advisory for CVE-2026-40973 requires use of the
    vulnerable ApplicationTemp path in a context such as server.servlet.session.persistent=true
    across restarts. This application does not enable server.servlet.session.persistent and uses
    Redis-backed Spring Session instead of persisted servlet-container sessions.
    -->
    <suppress>
        <gav regex="true">^.*org\.springframework\.boot:.*$</gav>
        <cve>CVE-2026-40973</cve>
    </suppress>

    <!--
    Not exploitable in this application. Spring's advisory for CVE-2026-40972 applies to remote
    Spring Boot DevTools when a remote secret is configured. This codebase only includes
    spring-boot-devtools as a test dependency and does not configure spring.devtools.remote.secret
    or other remote DevTools settings in the checked code or manifests.
    -->
    <suppress>
        <gav regex="true">^.*org\.springframework\.boot:.*$</gav>
        <cve>CVE-2026-40972</cve>
    </suppress>

</suppressions>
