{
  "name": "idam-web-public",
  "version": "1.0.0",
  "repository": "git@github.com:hmcts/idam-web-public.git",
  "license": "MIT",
  "engines": {
    "node": ">=18"
  },
  "devDependencies": {
    "@codeceptjs/allure-legacy": "^1.0.2",
    "allure-commandline": "^2.27.0",
    "chai": "^6.0.0",
    "codeceptjs": "^3.6.4",
    "deep-equal-in-any-order": "^2.0.0",
    "html_codesniffer": "^2.5.1",
    "jwt-decode": "^3.1.2",
    "mocha-junit-reporter": "^2.0.0",
    "mocha-multi": "^1.1.3",
    "node-fetch": "^2.6.1",
    "notifications-node-client": "^8.0.0",
    "pa11y": "^9.0.0",
    "playwright": "1.61.1",
    "proxy-agent": "^8.0.0"
  },
  "scripts": {
    "test-crossbrowser-e2e": "NODE_PATH=. codeceptjs run-multiple --all -c codecept.crossbrowser.conf.js --steps --grep '@crossbrowser' --reporter mocha-multi",
    "test-crossbrowser-report": "allure generate functional-output/cross-browser/reports/* -c -o functional-output/cross-browser/allure",
    "test-functional-report": "allure generate functional-output/functional/reports -c -o functional-output/functional/allure",
    "test-smoke-report": "allure generate functional-output/smoke/reports -c -o functional-output/smoke/allure",
    "test:crossbrowser": "yarn test-crossbrowser-e2e && yarn test-crossbrowser-report"
  }
}
