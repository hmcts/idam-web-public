<suppressions xmlns="https://jeremylong.github.io/DependencyCheck/dependency-suppression.1.3.xsd">

    <!-- JSTL/ XML‐based tags not used -->
    <suppress>
        <notes><![CDATA[
        file name: jstl-1.2.jar
        ]]></notes>
        <gav regex="true">^.*$</gav>
        <cve>CVE-2015-0254</cve>
    </suppress>

    <!-- Spring 2.x vulnerabilities until we move to Spring 3+ -->
    <suppress>
        <gav regex="true">^.*org\.springframework.*$</gav>
        <cve>CVE-2016-1000027</cve>
        <cve>CVE-2020-5408</cve>
        <cve>CVE-2024-38820</cve>
    </suppress>

    <!-- Logback CVEs blocked by Spring Boot version -->
    <suppress base="true">
        <gav regex="true">^.*logback.*$</gav>
        <cve>CVE-2023-6378</cve>
        <cve>CVE-2023-6481</cve>
    </suppress>

    <!--
    commons-configuration-1.8 is a transitive dependency of spring-cloud-starter-netflix-zuul:
    neither has an upgrade path
    -->
    <suppress>
        <gav regex="true">^.*commons-configuration.*$</gav>
        <cve>CVE-2025-46392</cve>
    </suppress>

    <!-- False positive: CVE applies to Go distribution, not Netflix Java stats jar -->
    <suppress>
        <notes><![CDATA[
        False positive: CVE-2026-33540 applies to github.com/distribution/distribution (Go),
        not pkg:maven/com.netflix.netflix-commons/netflix-statistics.
        ]]></notes>
        <gav regex="true">^com\.netflix\.netflix-commons:netflix-statistics$</gav>
        <cve>CVE-2026-33540</cve>
    </suppress>
</suppressions>
